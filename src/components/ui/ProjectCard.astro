---
import TechBadges from './TechBadges.astro';
import ProjectLinks from './ProjectLinks.astro';

interface Props {
  title: string;
  description: string;
  image: string;
  date: string;
  status: string;
  technologies: { name: string; icon?: string; color: string }[];
  url: {
    githubfrontend?: string;
    githubbackend?: string;
    github?: string;
    demo?: string;
  };
  featured?: boolean;
}

const { title, description, image, date, status, technologies, url, featured = false } = Astro.props;
---

{featured ? (
	<div class="p-4 rounded-lg shadow-lg shadow-slate-700 flex flex-col md:flex-row gap-6">
		<div class="overflow-hidden rounded-md md:w-2/5 flex-shrink-0" style="min-height: 24vh;">
			<img src={image} alt={title} class="w-full h-full object-cover rounded-md hover:scale-105 transition-transform duration-300" />
		</div>
		<div class="flex flex-col flex-1">
			<div class="flex items-center justify-between mb-2">
				<h2 class="text-2xl font-bold text-amber-300">{title}</h2>
				<p class={`text-gray-600 text-xs font-bold border border-gray-600 rounded-full px-2 py-0.5 ${status === 'Terminado' ? 'bg-[#7bd47b]' : 'bg-[#ecd36d]'}`}>{status}</p>
			</div>
			<div class="my-4">
				<TechBadges technologies={technologies} />
			</div>
			<p class="mt-2 text-white text-sm font-bold">{date}</p>
			<p class="my-4 text-gray-200 font-semibold">{description}</p>
			<ProjectLinks url={url} />
		</div>
	</div>
) : (
	<div class="p-4 rounded-lg shadow-lg shadow-slate-700 flex flex-col h-full">
		<div class="flex items-center justify-between mb-2">
			<h2 class="text-2xl font-bold text-amber-300">{title}</h2>
			<p class={`text-gray-600 text-xs font-bold border border-gray-600 rounded-full px-2 py-0.5 ${status === 'Terminado' ? 'bg-[#7bd47b]' : 'bg-[#ecd36d]'}`}>{status}</p>
		</div>
		<div class="my-4">
			<TechBadges technologies={technologies} />
		</div>
		<div class="overflow-hidden rounded-md" style="height: 24vh;">
			<img src={image} alt={title} class="w-full h-full rounded-md hover:scale-105 transition-transform duration-300" />
		</div>
		<p class="mt-2 text-white text-sm font-bold">{date}</p>
		<p class="my-4 text-gray-200 font-semibold">{description}</p>
		<ProjectLinks url={url} />
	</div>
)}